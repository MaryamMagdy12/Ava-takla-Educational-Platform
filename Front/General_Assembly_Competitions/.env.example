# Copy to `.env` and restart Vite (`npm run dev`).

# Backend — bind all interfaces so phones on Wi‑Fi can reach your PC:
#   php artisan serve --host=0.0.0.0 --port=8000
#
# In dev, API is http(s)://<same-host-as-this-page>:8000/api automatically
# (e.g. http://192.168.1.7:5174 → http://192.168.1.7:8000/api).
# On this machine only, `localhost` in the browser is rewritten to 127.0.0.1 for the API (IPv4).
#
# Optional overrides:
#   VITE_LARAVEL_PORT=8001
#   VITE_API_USE_REMOTE=true
#   VITE_API_URL=https://staging.example.com/api
