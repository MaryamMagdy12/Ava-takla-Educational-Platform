# =============================================================================
# Admin app — local development (Vite + Laravel)
# =============================================================================
# Dev API URL is built as http(s)://<same-host-as-the-browser>:8000/api so large
# file uploads go straight to PHP (not through the Vite dev proxy).
#
# Backend (separate terminal, from Mini_educatinal_platform/Backend):
#   php artisan serve --host=0.0.0.0 --port=8000
# Use 0.0.0.0 so http://192.168.x.x:5177 on your phone/LAN can reach http://192.168.x.x:8000
#
# Frontend (from Front/Admin_side):
#   npm run dev -- --host
#
# If Laravel is not on port 8000:
#   VITE_LARAVEL_PORT=8001
#
# If the Vite dev server proxies to a different Laravel origin (rare):
#   VITE_API_PROXY_TARGET=http://127.0.0.1:8001
#
# To call a remote/staging API from dev instead:
#   VITE_API_USE_REMOTE=true
#   VITE_API_URL=https://your-staging.example.com/api
#
# Production build: set VITE_API_URL in .env.production (full API base URL).
# =============================================================================
