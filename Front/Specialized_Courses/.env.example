# Copy to `.env` in this folder, then restart Vite (`npm run dev`).

# Laravel API base URL including `/api` (optional; default in code is http://127.0.0.1:8000/api in dev).
# VITE_API_URL=http://127.0.0.1:8000/api

# Google Sign-In — OAuth 2.0 *Web application* client ID (ends with .apps.googleusercontent.com).
# Must match Backend GOOGLE_CLIENT_ID exactly. Console: Credentials → Create OAuth client ID → Web application.
# Google Cloud → Credentials → your Web client → Authorized JavaScript origins:
# add every origin you use in the browser (scheme + host + port). Examples:
#   http://localhost:5175   http://127.0.0.1:5175   (Google treats these as different)
# If you open the Network URL from `npm run dev`, add that too (e.g. http://192.168.1.10:5175).
#
# Optional: leave empty and set only GOOGLE_CLIENT_ID in ../../Backend/.env — Vite reads it at dev/build time.
# If Backend lives elsewhere, set SPECIAL_LEARNER_BACKEND_ENV to the full path of Backend/.env (Windows example: G:\\Projects\\Backend\\.env).
VITE_GOOGLE_CLIENT_ID=
