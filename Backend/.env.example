APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_INACTIVITY_TIMEOUT_MINUTES=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
SANCTUM_EXPIRATION=120
MAX_DOCUMENT_UPLOAD_MB=50
MAX_AUDIO_UPLOAD_MB=200
MAX_VIDEO_UPLOAD_MB=1024
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Real SMTP example (Gmail): host must be smtp.gmail.com — not your website domain.
# Use an App Password (Google Account → Security → 2-Step Verification → App passwords).
# MAIL_USERNAME must match the mailbox you authenticate as (usually same as MAIL_FROM_ADDRESS).
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_TIMEOUT=30

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# System super admin — full account from .env only (no code defaults). Required for seeding / admin login bootstrap.
SYSTEM_ADMIN_NAME="System Admin"
SYSTEM_ADMIN_USERNAME=admin
SYSTEM_ADMIN_EMAIL=admin@example.com
# Min 12 characters; use a strong unique value (never commit real secrets).
SYSTEM_ADMIN_PASSWORD=Admin@123456

# Student permanent password (one-time at create/reset): level prefix + first 3 letters of first name + student_unique_id.
# Prefixes per level: config/student_accounts.php. Logic: app/Services/StudentAccountService.php::derivePermanentPassword().

# Google Sign-In (Specialized Courses): OAuth 2.0 *Web application* client ID (…apps.googleusercontent.com).
# Must match the Specialized Courses SPA (VITE_GOOGLE_CLIENT_ID or value injected by that app’s Vite config from this file).
# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID → Web application.
# Authorized JavaScript origins: include every dev URL you use (Google treats hostnames separately), e.g.
#   http://localhost:5175   http://127.0.0.1:5175   and any Network URL from Vite (http://192.168.x.x:5175), plus production SPA origin(s).
GOOGLE_CLIENT_ID=
